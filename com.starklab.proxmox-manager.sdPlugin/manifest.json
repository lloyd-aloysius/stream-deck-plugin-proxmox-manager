{
	"Name": "Proxmox Manager",
	"Version": "1.0.0.0",
	"Author": "Lloyd",
	"Description": "Monitor Proxmox VE servers and control VMs and containers from your Stream Deck. Real-time status, resource gauges, and lifecycle actions.",
	"Category": "Proxmox Manager",
	"CategoryIcon": "imgs/plugin/category-icon",
	"Icon": "imgs/plugin/plugin-icon",
	"CodePath": "bin/plugin.js",
	"UUID": "com.starklab.proxmox-manager",
	"SDKVersion": 2,
	"Software": {
		"MinimumVersion": "6.5"
	},
	"OS": [
		{ "Platform": "mac", "MinimumVersion": "12" },
		{ "Platform": "windows", "MinimumVersion": "10" }
	],
	"Nodejs": {
		"Version": "20",
		"Debug": "enabled"
	},
	"Actions": [
		{
			"Name": "Server Overview",
			"UUID": "com.starklab.proxmox-manager.server-overview",
			"Tooltip": "Opens a folder showing the status of a Proxmox server.",
			"Icon": "imgs/actions/server-overview/icon",
			"PropertyInspectorPath": "pi/server-overview.html",
			"Controllers": ["Keypad"],
			"States": [{ "Image": "imgs/actions/server-overview/key" }]
		},
		{
			"Name": "Server Stats",
			"UUID": "com.starklab.proxmox-manager.server-stats",
			"Tooltip": "Shows a resource gauge for a Proxmox server.",
